RAINROUTE_CWA_API_KEY=CWA-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
RAINROUTE_ORS_API_KEY=your-openrouteservice-key
RAINROUTE_NOMINATIM_USER_AGENT=rainroute (you@example.com)
# Optional overrides:
# RAINROUTE_RADAR_CACHE_TTL_S=600
# RAINROUTE_SAMPLE_INTERVAL_M=500
# RAINROUTE_CWA_BASE_URL=https://opendata.cwa.gov.tw
# RAINROUTE_CORS_ORIGINS=*
# Routing backend: "ors" (default, needs RAINROUTE_ORS_API_KEY) or "osrm" (key-less public server)
# RAINROUTE_ROUTING_BACKEND=ors
# RAINROUTE_OSRM_BASE_URL=https://router.project-osrm.org
